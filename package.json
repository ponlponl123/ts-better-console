{
  "name": "ts-better-console",
  "description": "A TypeScript library that provides enhanced console logging capabilities with improved type safety and formatting options.",
  "version": "0.1.1",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "author": {
    "name": "Ponlponl123",
    "email": "itsme@ponlponl123.com",
    "url": "https://github.com/Ponlponl123/ts-better-console"
  },
  "keywords": [
    "typescript",
    "console",
    "logging",
    "cli",
    "spinner",
    "progress",
    "menu",
    "card",
    "button"
  ],
  "license": "MIT",
  "homepage": "https://ponlponl123.github.io/ts-better-console",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ponlponl123/ts-better-console.git"
  },
  "scripts": {
    "bun:build": "bun run clear-dist && bun build src/index.ts --outdir dist && bunx tsc",
    "node:build": "npm run clear-dist && tsc --outDir dist",
    "build": "command -v bun >/dev/null 2>&1 && bun run bun:build || npm run node:build",
    "bun:test": "bun test src",
    "node:test": "npm run node:build && node dist/index.test.js",
    "node:dev": "tsc --watch",
    "bun:dev": "bun run ./src/index.ts --watch",
    "dev": "command -v bun >/dev/null 2>&1 && bun run bun:dev || npm run node:dev",
    "lint": "eslint . --ext .ts",
    "unix:clear-dist": "rm -rf dist",
    "win:clear-dist": "rmdir /s /q dist",
    "clear-dist": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
